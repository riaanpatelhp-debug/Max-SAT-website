# ============================================================
# Example environment file — COPY to ".env" and fill in real values.
# NEVER commit the real ".env" (it is git-ignored). NEVER expose any
# of these values in client-side HTML/JS — they belong only on the server.
# ============================================================

# --- Server ---
NODE_ENV=production
PORT=8080

# --- CORS: comma-separated list of allowed origins for the API ---
ALLOWED_ORIGINS=https://maxpotentiallearning.com,https://www.maxpotentiallearning.com

# --- Secrets / API keys (server-side only) ---
# Generate strong values, store in your host's secret manager, and ROTATE on a schedule.
# Support two keys at a time (CURRENT + PREVIOUS) to enable zero-downtime rotation.
EMAIL_API_KEY=replace_me_current
EMAIL_API_KEY_PREVIOUS=
SESSION_SECRET=replace_me_with_64_random_hex_chars

# --- Rate limiting (overridable defaults; see server/app.js) ---
RATE_LIMIT_WINDOW_MS=900000        # 15 minutes
RATE_LIMIT_MAX=100                  # general requests / window / client
RATE_LIMIT_SENSITIVE_MAX=5         # auth/contact requests / window / client
